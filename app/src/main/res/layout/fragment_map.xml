<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F5">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1D9E75"
            app:title="City Zone Heatmap"
            app:titleTextColor="#FFFFFF"
            app:subtitle="Tap a filter to explore · Nagpur"
            app:subtitleTextColor="#CCFFFFFF"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Map fills entire screen -->
    <fragment
        android:id="@+id/mapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Filter buttons overlay (top) -->
    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="#CC000000"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/filterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="ALL"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1D9E75"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterAqi"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🌫️ AQI"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#555555"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterTraffic"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🚦 Traffic"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#555555"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterEnergy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⚡ Energy"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#555555"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterWater"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="💧 Water"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#555555"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterWaste"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🗑️ Waste"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#555555"
                app:cornerRadius="18dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Color scale legend (right side) -->
    <LinearLayout
        android:id="@+id/legendLayout"
        android:layout_width="40dp"
        android:layout_height="180dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="#CC000000"
        android:padding="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#E53935" />
        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#FF5722" />
        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#FF9800" />
        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#FFC107" />
        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#8BC34A" />
        <View
            android:layout_width="16dp"
            android:layout_height="20dp"
            android:background="#1D9E75" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOW"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Bottom detail card (hidden by default) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvCardEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌫️"
                    android:textSize="28sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Air Quality"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:id="@+id/tvCardLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sector 4, Nagpur"
                        android:textSize="12sp"
                        android:textColor="#888888" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCardStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Moderate"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="#F5F5F5"
                    android:padding="10dp">
                    <TextView
                        android:id="@+id/tvCardValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="142"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:id="@+id/tvCardUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AQI"
                        android:textSize="11sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="#F5F5F5"
                    android:padding="10dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:id="@+id/tvCardAdvice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wear mask outdoors"
                        android:textSize="11sp"
                        android:textColor="#444444"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>